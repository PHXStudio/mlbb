[configuration]
entry_symbol = "example_library_init"
compatibility_minimum = "4.1"

[libraries]
macos.editor = "res://bin/libproto.macos.template_debug.universal.dylib"
macos.debug = "res://bin/libproto.macos.template_debug.universal.dylib"
macos.release = "res://bin/libproto.macos.template_release.universal.dylib"


# iOS
ios.debug.arm64 = "res://bin/libproto.ios.template_debug.arm64.dylib"
ios.release.arm64 = "res://bin/libproto.ios.template_release.arm64.dylib"